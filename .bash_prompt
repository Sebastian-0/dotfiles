#!/bin/bash
root_path="$(dirname -- "${BASH_SOURCE[0]}")"

. "$root_path/utils/ssh_env.sh"

SEB_PROMPT_R='\e[0m'
SEB_PROMPT_COL_STATUS_OK='\e[32m'
SEB_PROMPT_COL_STATUS_ERR='\e[38;5;124m'
SEB_PROMPT_COL_TIME='\e[37m'
SEB_PROMPT_COL_HOST='\e[33m'
SEB_PROMPT_COL_SSH_ERR='\e[38;5;124m'
SEB_PROMPT_COL_SSH_LOCKED='\e[38;5;208m'
SEB_PROMPT_COL_SSH_UNLOCKED='\e[32m'
SEB_PROMPT_COL_GIT='\e[38;5;12m'
SEB_PROMPT_COL_GIT_BRANCH='\e[38;5;12m'
SEB_PROMPT_COL_GIT_TAG='\e[38;5;178m'
SEB_PROMPT_COL_GIT_COMMIT='\e[38;5;60m'
SEB_PROMPT_COL_GIT_DETACHED='\e[38;5;13m'
SEB_PROMPT_COL_DIR='\e[37m'
SEB_PROMPT_COL_SUBSHELL='\e[38;5;98m'
SEB_PROMPT_COL_ROOT='\e[38;5;220m'

# Timer functionality courtesy of Nicolas Thery:
# https://stackoverflow.com/a/34812608
function _seb_prompt_time_now {
    date +%s%N
}

function _seb_prompt_timer_start {
    # Only run for commands not in the prompt, otherwise the timer shows the wrong value
    if [[ "$PROMPT_COMMAND" != *$BASH_COMMAND* ]]; then
        _seb_prompt_time_start=${timer_start:-$(_seb_prompt_time_now)}
    fi
}

function _seb_prompt_time {
    local now
    now=$(_seb_prompt_time_now)
    # The timer is not started in case of Ctrl+C, make time diff == 0
    if [ -z "${_seb_prompt_time_start:-}" ]; then
        _seb_prompt_time_start="$now"
    fi
    local delta=$((now - _seb_prompt_time_start))
    echo "\[$SEB_PROMPT_R$SEB_PROMPT_COL_TIME\]($( # Subshell to avoid leaking sourced symbols
        . "$root_path/utils/time.sh"
        nanos_to_str $delta
    )) \t "
}

function _seb_prompt_exit_code() {
    local exit="$1"
    if [ "$exit" = "0" ]; then
        echo "\[$SEB_PROMPT_R${SEB_PROMPT_COL_STATUS_OK}\][ ¾░ä¼ ] "
    else
        echo "\[$SEB_PROMPT_R${SEB_PROMPT_COL_STATUS_ERR}\][ ’ā¦ $exit ] "
    fi
}

function _seb_prompt_ssh() {
    local start
    if [ ! -f "$SSH_ADD_TIME" ]; then
        start=0
    else
        start="$(cat "$SSH_ADD_TIME")"
    fi

    local current="$(_seb_prompt_time_now)"
    local delta=$((SSH_ADD_EXPIRY_SECONDS * 1000000000 - (current - start)))
    if ! pgrep ssh-agent > /dev/null; then
        # No SSH agent is running at all
        echo "\[$SEB_PROMPT_R$SEB_PROMPT_COL_SSH_ERR\]< ¾░╗ī -- > "
    elif [ -z "$SSH_AGENT_PID" ] || ! ps -p "$SSH_AGENT_PID" > /dev/null || [ "$delta" -lt 0 ]; then
        # TODO: PID is still valid after the key expires, maybe the delta check is enough? Otherwise add back: ! ssh-add -l > /dev/null
        # No key registered, or key expired
        echo "\[$SEB_PROMPT_R$SEB_PROMPT_COL_SSH_LOCKED\]< ¾░”× -- > "
    else
        local ssh_expiry_time="$( # Subshell to avoid leaking sourced symbols
            . "$root_path/utils/time.sh"
            nanos_to_str $delta
        )"
        echo "\[$SEB_PROMPT_R$SEB_PROMPT_COL_SSH_UNLOCKED\]< ¾░Ģź $ssh_expiry_time > "
    fi
}

function _seb_prompt_host() {
    if [ -z "${SSH_CONNECTION:-}" ]; then
        echo "\[$SEB_PROMPT_R$SEB_PROMPT_COL_HOST\][\u@] "
    else
        echo "\[$SEB_PROMPT_R$SEB_PROMPT_COL_HOST\][\u@\h] "
    fi
}

function _seb_prompt_git() {
    if git status &> /dev/null; then
        local provider="¾░Ŗó"
        # local repo="$(basename "$(git rev-parse --show-toplevel)")"
        local remote_repo="$(git config --get remote.origin.url)"
        if [ -n "$remote_repo" ]; then
            #     repo="$(basename -s .git "$remote_repo")"
            if [[ "$remote_repo" = *github.com* ]]; then
                provider=¾░Ŗż
            fi
            if [[ "$remote_repo" = *bitbucket.com* ]]; then
                provider=¾░Āä
            fi
            if [[ "$remote_repo" = *gitlab.com* ]]; then
                provider=¾░«Ā
            fi
        fi

        local is_detached=false
        local branch="$(git branch --show-current)"
        if [ -n "$branch" ]; then
            branch="\[$SEB_PROMPT_COL_GIT_BRANCH\]$branch"
        else
            is_detached=true
        fi

        local tag="$(git tag --points-at HEAD | paste -sd' ' -)"
        if [ -n "$tag" ]; then
            tag="\[$SEB_PROMPT_COL_GIT_TAG\] ¾░ō╗ $tag"
        fi

        local commit="$(git rev-parse --short HEAD)"
        if [ -n "$commit" ]; then
            commit="\[$SEB_PROMPT_COL_GIT_COMMIT\] ’ÉŚ $commit"
        fi

        if [ "$is_detached" == false ]; then
            echo "\[$SEB_PROMPT_R$SEB_PROMPT_COL_GIT\]($provider $branch$tag\[$SEB_PROMPT_COL_GIT\]) "
        else
            # For detached state we want to always show either tag or commit hash
            if [ -z "$tag" ]; then
                tag="$commit"
            fi
            echo "\[$SEB_PROMPT_R$SEB_PROMPT_COL_GIT\]($provider \[$SEB_PROMPT_COL_GIT_DETACHED\]DETACHED$tag\[$SEB_PROMPT_COL_GIT\]) "
        fi
    fi
}

function _seb_prompt_working_dir() {
    echo "\[$SEB_PROMPT_R$SEB_PROMPT_COL_DIR\]\w"
}

function _seb_prompt_input_char() {
    echo "\[$SEB_PROMPT_R\]\$"
}

function _seb_prompt_join_by {
    local d="${1-}" f="${2-}"
    if shift 2; then
        printf "%s" "$f" "${@/#/$d}"
    fi
}

function _seb_prompt_sessions() {
    local sessions=()
    if [ -n "$IN_NIX_SHELL" ]; then
        # NOTE: This check is not sufficient since it only works for `nix-shell` but not for `nix shell`, see:
        # https://github.com/NixOS/nix/issues/3862#issuecomment-707320241
        sessions+=("¾▒äģ nix")
    fi
    if [ -n "$SSH_CONNECTION" ] || [ -n "$SSH_TTY" ]; then
        sessions+=("­¤¢¦  ssh")
    fi
    if [ "$SHLVL" -eq 2 ]; then
        sessions+=("Ņ»Ŗ bash")
    fi
    if [ "$SHLVL" -gt 2 ]; then
        sessions+=("Ņ»Ŗ bash ($SHLVL)")
    fi
    if [ -n "$YAZI_LEVEL" ]; then
        sessions+=("Ņ×Ģ yazi")
    fi
    if [ -n "$VIRTUAL_ENV" ]; then
        sessions+=("¾░īĀ venv")
    fi
    if [ -n "$DIRENV_DIR" ]; then
        sessions+=("¾░½¦ direnv")
    fi
    if [ "${#sessions[@]}" -gt 0 ]; then
        echo "\[$SEB_PROMPT_R$SEB_PROMPT_COL_SUBSHELL\]< $(_seb_prompt_join_by " | " "${sessions[@]}") > "
    fi
}

function _seb_prompt() {
    local ec="$?"
    local ret="$(_seb_prompt_exit_code $ec)"
    local time="$(_seb_prompt_time)"
    local ssh="$(_seb_prompt_ssh)"
    local host="$(_seb_prompt_host)"
    local git="$(_seb_prompt_git)"
    local dir="$(_seb_prompt_working_dir)"
    local input_char="$(_seb_prompt_input_char)"
    local sessions="$(_seb_prompt_sessions)"

    local root=""
    if [ $EUID -eq 0 ]; then
        # NOTE: This will probably never be useful because we don't use this prompt when we are root
        root="\[$SEB_PROMPT_R$SEB_PROMPT_COL_ROOT\]( ’Üż ) "
    fi

    unset _seb_prompt_time_start
    PS1="\nŌöī$ret$time$host$git$ssh$dir\n$sessions$root$input_char "
}
if [[ "$PROMPT_COMMAND" != *_seb_prompt* ]]; then
    trap '_seb_prompt_timer_start' DEBUG
    if [ -z "$PROMPT_COMMAND" ]; then
        export PROMPT_COMMAND="_seb_prompt"
    else
        export PROMPT_COMMAND="$PROMPT_COMMAND; _seb_prompt"
    fi
fi
