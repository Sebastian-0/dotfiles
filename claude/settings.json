{
	"env": {
		"EDITOR": "nvim",
		"VISUAL": "nvim"
	},
	"permissions": {
		"allow": [
			"Bash(gh repo view *)",
			"Bash(gh pr *)",
			"Bash(gh run *)",
			"Bash(gh api *)",
			"Bash(git commit *)",
			"Bash(git add *)",
			"Bash(git log *)",
			"Bash(git mv *)",
			"Bash(find *)",
			"Bash(df *)",
			"Bash(du *)",
			"Bash(ls *)",
			"Bash(jq *)",
			"Bash(wc *)",
			"Bash(grep *)",
			"Bash(black *)",
			"Bash(clang-format *)",
			"Bash(biome *)",
			"Bash(rustfmt *)",
			"Bash(shfmt *)",
			"Bash(lua-format *)",
			"Bash(zig fmt *)",
			"Search(*)",
			"Write(/tmp/*)"
		]
	},
	"statusLine": {
		"type": "command",
		"command": "bash \"$HOME/.claude/statusline-command.sh\""
	}
}
