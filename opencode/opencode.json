{
	"$schema": "https://opencode.ai/config.json",
	"instructions": ["~/.config/opencode/rules.md"],
	"permission": {
		"bash": {
			"*": "ask",
			"ls *": "allow",
			"cat *": "allow",
			"head *": "allow",
			"tail *": "allow",
			"git status*": "allow",
			"git log*": "allow",
			"git diff*": "allow",
			"grep *": "allow",
			"zig *": "allow"
		},
		"skill": {
			"*": "ask"
		},
		"external_directory": "ask"
	}
}
